{
    "installCommand": "npm install && cd frontend && npm install && cd ../backend && npx prisma generate",
    "buildCommand": "cd frontend && npm run build",
    "outputDirectory": "frontend/dist",
    "framework": null,
    "functions": {
        "api/index.js": {
            "maxDuration": 30,
            "includeFiles": [
                "backend/**",
                "node_modules/**"
            ]
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
